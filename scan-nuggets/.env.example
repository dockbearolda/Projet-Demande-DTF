# All endpoints used are public + unauthenticated — there are NO secrets required.
# These knobs only tune volume and politeness. Copy to .env to override.

# Where the SQLite DB lives (default: ./data/nuggets.sqlite)
# NUGGETS_DB=./data/nuggets.sqlite

# --- demand stage (Google autocomplete) ---
# Delay between autocomplete calls, ms (be polite to a public endpoint)
DEMAND_RL_MS=300

# --- enrich stage (live Chrome Web Store, STRICT rate limit) ---
# One request every N ms. Spec mandates >= 3000 (1 req / 3s).
ENRICH_RL_MS=3000
# How many top candidates to enrich (keep the live volume small)
ENRICH_LIMIT=60
# Honest identifying User-Agent for the public-page fetches
ENRICH_UA=nuggets-research/0.1 (+local perso research; dockbear@gmail.com)
