# --- clients-api : variables d'environnement ---

# Connexion PostgreSQL. Railway l'injecte automatiquement quand un service
# Postgres est attaché ; en local, pointe vers ta base de dev.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clients

# Mettre à true si la connexion exige TLS (Postgres managé externe).
# Inutile pour le réseau interne Railway. Détecté aussi via sslmode=require.
DATABASE_SSL=false

# Clé d'API exigée dans le header X-API-Key sur toutes les routes /clients.
# Génère un secret long et aléatoire : `openssl rand -hex 32`
API_KEY=change-me-with-a-long-random-secret

# Port HTTP. Railway l'injecte automatiquement ; 3000 par défaut en local.
PORT=3000
